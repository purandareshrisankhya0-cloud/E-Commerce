# Firebase Configuration - Copy this to .env and fill in your values
# Get these values from your Firebase Console > Project Settings

# Firebase Web SDK Config (for frontend)
FIREBASE_API_KEY=your_api_key_here
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_APP_ID=1:123456789:web:abc123456789

# Firebase Admin SDK (for backend - path to JSON key file)
# Option 1: Set the full path to your Firebase service account JSON file
FIREBASE_KEY_PATH=store/e-commerce-aa53b-firebase-adminsdk-fbsvc-8ab0cf2976.json

# Django Secret Key (change this in production!)
DJANGO_SECRET_KEY=your-secret-key-here

